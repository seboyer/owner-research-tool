# ============================================================
# NYC Landlord Finder — Environment Variables
# Copy this to .env and fill in your values.
# ============================================================

# --- Supabase ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key   # Use service key (not anon) for server-side writes

# --- Anthropic (Claude) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- OpenAI ---
OPENAI_API_KEY=sk-...

# --- Zoominfo ---
ZOOMINFO_CLIENT_ID=your-client-id
ZOOMINFO_PRIVATE_KEY=your-private-key        # Used for JWT auth
ZOOMINFO_USERNAME=your@email.com             # For password auth fallback

# --- NYC OpenData (Socrata) ---
# Register free at https://data.cityofnewyork.us to get higher rate limits
NYC_OPENDATA_APP_TOKEN=your-app-token

# --- OpenCorporates ---
# Free: 50 req/day. Paid: much more. https://opencorporates.com/api_accounts
OPENCORPORATES_API_KEY=your-api-key

# --- ACRIS PDF Download (anti-bot tiers) ---
# Tier 1: Playwright (installed via requirements.txt, no key needed)
# Tier 2: Browserless.io — cloud browser. https://www.browserless.io
BROWSERLESS_API_KEY=your-browserless-key
# Tier 3: ScraperAPI — proxy + rendering. https://www.scraperapi.com
SCRAPERAPI_KEY=your-scraperapi-key

# --- Multi-Source Contact Enrichment (all optional — system degrades gracefully) ---
BATCHDATA_API_KEY=                           # https://developer.batchdata.com — V3 skip trace (phones+emails by property address). Budget tier.
WHITEPAGES_API_KEY=                          # https://pro.whitepages.com/developer
PROPERTYRADAR_API_KEY=                       # https://www.propertyradar.com/api
GOOGLE_PLACES_API_KEY=                       # https://console.cloud.google.com
HUNTER_API_KEY=                              # https://hunter.io/api
PROXYCURL_API_KEY=                           # https://nubela.co/proxycurl

# --- Auto-search worker toggle ---
# When false (default), the cron-based daily/weekly pipelines are disabled.
# The Airtable manual-feed webhook still works in either state.
# Flip to "true" once you've validated the pipeline against live data.
AUTO_SEARCH_ENABLED=false

# --- Airtable webhook (manual address feed) ---
# Generate a random secret with: openssl rand -hex 32
# Configure the same value in the Airtable automation HTTP step.
AIRTABLE_WEBHOOK_SECRET=
# Personal access token from https://airtable.com/create/tokens — needs
# data.records:write scope on the LL Pipeline base.
AIRTABLE_API_KEY=
# IDs default to the LL Pipeline base / Addresses table — override if needed.
AIRTABLE_BASE_ID=appstQVl7JeMfr7d0
AIRTABLE_ADDRESS_TABLE_ID=tblVOwshwfY0F3gSS
AIRTABLE_BBL_FIELD_ID=fldYiP7RhhoYx6QpS
AIRTABLE_HPD_FIELD_ID=fldqyrQmuJlglgXqu

# --- Pipeline Settings ---
LOG_LEVEL=INFO
ENVIRONMENT=production                       # 'development' | 'production'

# How many buildings/entities to process per run (set lower for testing)
HPD_BATCH_SIZE=1000
ACRIS_BATCH_SIZE=500
ENRICHMENT_BATCH_SIZE=50                     # Zoominfo calls per run (watch your credits)

# How many days back to look for new ACRIS transfers
ACRIS_LOOKBACK_DAYS=30

# Minimum portfolio size to trigger Zoominfo enrichment (save credits for big landlords)
ZOOMINFO_MIN_PORTFOLIO_SIZE=3
